---
import { shared } from '../data/content';

const { t } = Astro.props;

// Email split so the address is assembled by JS, not left in the HTML for bots.
const [emailUser, emailDomain] = shared.email.split('@');

const work = shared.workBase.map((b, i) => ({ ...b, ...t.work[i] }));
const companies = shared.companyLinks.map((c, i) => ({ ...c, ...t.companies[i] }));
const education = shared.eduBase.map((e, i) => ({ ...e, ...t.education[i] }));
---

<!-- ============================ HERO ============================ -->
<section class="hero">
  <div class="wrap hero__inner">
    <p class="hero__eyebrow">{t.role}</p>
    <h1 class="hero__name">{shared.name}</h1>
    <p class="hero__tagline">{t.tagline}</p>
    <div class="hero__actions">
      <a class="btn btn--solid" href="#work">{t.cta.work}</a>
      <a class="btn btn--ghost" href="#contact">{t.cta.contact}</a>
    </div>
    <div class="hero__meta">
      <span>{t.basedIn} {t.cities.join(' & ')} · {t.availability}</span>
      <span class="dot" aria-hidden="true">•</span>
      <span>{t.heroFormats}</span>
    </div>
  </div>
  <div class="hero__scroll" aria-hidden="true">{t.heroScroll}</div>
</section>

<!-- ============================ ABOUT ============================ -->
<section id="about" class="section">
  <div class="wrap">
    <p class="section__label reveal">{t.about.heading}</p>
    <div class="about">
      <figure class="about__portrait reveal">
        <img src={shared.portrait} alt={t.about.portraitAlt} width="600" height="800" />
      </figure>
      <div class="about__body">
        <div class="about__lead">
          {t.about.paragraphs.map((p) => <p class="about__p reveal">{p}</p>)}
        </div>
        <ul class="about__list reveal">
          {t.about.personal.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- ========================== WHAT I DO ========================== -->
<section id="services" class="section">
  <div class="wrap">
    <p class="section__label reveal">{t.servicesLabel}</p>
    <div class="services">
      {
        t.services.map((s) => (
          <article class="service reveal">
            <h3 class="service__title">{s.title}</h3>
            <p class="service__body">{s.body}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<!-- ========================= HOW I WORK ========================= -->
<section id="approach" class="section">
  <div class="wrap">
    <p class="section__label reveal">{t.approachLabel}</p>
    <p class="approach__lead reveal">{t.approachIntro}</p>
    <div class="approach">
      {
        t.strengths.map((s, i) => (
          <article class="approach__item reveal">
            <span class="approach__num">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="approach__title">{s.title}</h3>
            <p class="approach__body">{s.body}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<!-- ======================== SELECTED WORK ======================== -->
<section id="work" class="section">
  <div class="wrap">
    <p class="section__label reveal">{t.workLabel}</p>
    <ul class="work-grid">
      {
        work.map((p) => (
          <li class="work-card reveal">
            <figure class="work-card__media">
              {p.image ? (
                <img src={p.image} alt={p.title} loading="lazy" width="600" height="900" />
              ) : (
                <div class="work-card__ph">
                  <span class="work-card__ph-mark">{p.format}</span>
                </div>
              )}
              <span class="work-card__year">{p.year}</span>
            </figure>
            <div class="work-card__info">
              <h3 class="work-card__title">{p.title}</h3>
              <p class="work-card__meta">{p.format} · {p.role}</p>
            </div>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<!-- ========================= COMPANIES ========================= -->
<section id="companies" class="section">
  <div class="wrap">
    <p class="section__label reveal">{t.companiesLabel}</p>
    <div class="companies">
      {
        companies.map((c) => (
          <a class="company reveal" href={c.href} target="_blank" rel="noopener">
            <div class="company__top">
              <h3 class="company__name">{c.name}</h3>
              <span class="company__arrow" aria-hidden="true">↗</span>
            </div>
            <span class="company__place">{c.place}</span>
            <p class="company__body">{c.body}</p>
          </a>
        ))
      }
    </div>
    <div class="clients-strip reveal">
      <span class="clients-strip__label">{t.clientsLabel}</span>
      <div class="clients-strip__list">
        {shared.clients.map((c) => <span class="client">{c}</span>)}
      </div>
    </div>
  </div>
</section>

<!-- ========================= EDUCATION ========================= -->
<section id="education" class="section">
  <div class="wrap">
    <p class="section__label reveal">{t.educationLabel}</p>
    <ul class="education">
      {
        education.map((e) => (
          <li class="edu reveal">
            <h3 class="edu__degree">{e.degree}</h3>
            <p class="edu__inst">{e.institution}</p>
            {e.detail && <p class="edu__detail">{e.detail}</p>}
          </li>
        ))
      }
    </ul>
  </div>
</section>

<!-- ========================== CONTACT ========================== -->
<section id="contact" class="section contact">
  <div class="wrap">
    <p class="section__label reveal">{t.contactLabel}</p>
    <h2 class="contact__headline reveal">{t.contact.headline}</h2>
    <p class="contact__intro reveal">{t.contact.intro}</p>
    <a class="contact__email reveal js-mail" data-user={emailUser} data-domain={emailDomain} href="#" aria-label="Email">{emailUser} [at] {emailDomain}</a>
    <div class="contact__social reveal">
      {shared.social.map((s) => <a href={s.href} target="_blank" rel="noopener">{s.label}</a>)}
    </div>
  </div>
</section>

<style>
  /* ------------------------------- HERO ------------------------------- */
  .hero {
    position: relative;
    min-height: 92vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(60% 55% at 50% 0%, rgba(255, 255, 255, 0.06), transparent 70%),
      radial-gradient(40% 40% at 85% 90%, rgba(255, 255, 255, 0.04), transparent 70%);
    pointer-events: none;
  }
  .hero__inner {
    position: relative;
    padding-block: clamp(6rem, 16vh, 10rem);
  }
  .hero__eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.28em;
    font-size: 0.78rem;
    color: var(--text-muted);
    margin: 0 0 1.5rem;
  }
  .hero__name {
    font-size: clamp(3.2rem, 12vw, 8rem);
    letter-spacing: -0.03em;
  }
  .hero__tagline {
    margin: 1.75rem 0 0;
    max-width: 34ch;
    font-size: clamp(1.15rem, 2.6vw, 1.6rem);
    line-height: 1.35;
    color: var(--text-muted);
    font-family: var(--font-display);
    font-weight: 300;
  }
  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 2.75rem;
  }
  .hero__meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 3rem;
    color: var(--text-dim);
    font-size: 0.85rem;
    letter-spacing: 0.02em;
  }
  .hero__meta .dot {
    color: var(--border-strong);
  }
  .hero__scroll {
    position: absolute;
    left: 50%;
    bottom: 1.75rem;
    transform: translateX(-50%);
    font-size: 0.68rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--text-dim);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.8rem 1.5rem;
    border-radius: 999px;
    font-size: 0.9rem;
    letter-spacing: 0.01em;
    border: 1px solid transparent;
    transition: transform 0.2s ease, background 0.25s ease, color 0.25s ease, border-color 0.25s ease;
  }
  .btn:hover {
    transform: translateY(-2px);
  }
  .btn--solid {
    background: var(--text);
    color: var(--bg);
  }
  .btn--solid:hover {
    background: #fff;
  }
  .btn--ghost {
    border-color: var(--border-strong);
    color: var(--text);
  }
  .btn--ghost:hover {
    background: rgba(255, 255, 255, 0.06);
  }

  /* ------------------------------- ABOUT ------------------------------ */
  .about {
    display: grid;
    gap: clamp(2rem, 5vw, 4rem);
    grid-template-columns: 1fr;
  }
  .about__portrait {
    margin: 0;
    max-width: 420px;
  }
  .about__portrait img {
    width: 100%;
    height: auto;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    object-position: 58% center;
    border-radius: 14px;
    border: 1px solid var(--border);
    background: var(--bg-soft);
  }
  .about__p {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(1.25rem, 2.4vw, 1.7rem);
    line-height: 1.5;
    color: var(--text);
    margin: 0 0 1.4rem;
    max-width: 46ch;
  }
  .about__list {
    list-style: none;
    margin: 2.5rem 0 0;
    padding: 0;
  }
  .about__list li {
    padding: 1rem 0;
    border-top: 1px solid var(--border);
    color: var(--text-muted);
    font-size: 0.98rem;
  }
  .about__list li:last-child {
    border-bottom: 1px solid var(--border);
  }
  @media (min-width: 860px) {
    .about {
      grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.5fr);
      align-items: start;
    }
    .about__portrait {
      position: sticky;
      top: 96px;
    }
  }

  /* ----------------------------- SERVICES ----------------------------- */
  .services {
    display: grid;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    grid-template-columns: 1fr;
  }
  .service {
    background: var(--bg);
    padding: clamp(1.75rem, 4vw, 2.75rem);
  }
  .service__title {
    font-size: 1.5rem;
    margin-bottom: 0.75rem;
  }
  .service__body {
    color: var(--text-muted);
    margin: 0;
    font-size: 0.98rem;
    max-width: 40ch;
  }
  @media (min-width: 720px) {
    .services {
      grid-template-columns: 1fr 1fr;
    }
  }

  /* ----------------------------- APPROACH ----------------------------- */
  .approach__lead {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(1.3rem, 2.8vw, 1.9rem);
    line-height: 1.4;
    color: var(--text);
    max-width: 30ch;
    margin: 0 0 clamp(2.5rem, 5vw, 3.5rem);
  }
  .approach {
    display: grid;
    gap: 2.5rem 2rem;
    grid-template-columns: 1fr;
  }
  .approach__item {
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-strong);
  }
  .approach__num {
    font-family: var(--font-display);
    font-size: 0.9rem;
    color: var(--text-dim);
    letter-spacing: 0.05em;
  }
  .approach__title {
    margin: 0.6rem 0 0.7rem;
    font-size: clamp(1.4rem, 2.6vw, 1.75rem);
  }
  .approach__body {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.98rem;
    max-width: 34ch;
  }
  @media (min-width: 720px) {
    .approach {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* ------------------------------- WORK ------------------------------- */
  .work-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.5rem, 3.5vw, 2.5rem) clamp(1rem, 2.5vw, 1.75rem);
  }
  .work-card {
    display: flex;
    flex-direction: column;
  }
  .work-card__media {
    position: relative;
    margin: 0;
    aspect-ratio: 16 / 9;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--bg-soft);
  }
  .work-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .work-card:hover .work-card__media img {
    transform: scale(1.05);
  }
  .work-card__ph {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    background:
      radial-gradient(120% 80% at 50% 0%, rgba(255, 255, 255, 0.05), transparent 60%),
      linear-gradient(160deg, #161618, #0c0c0e);
  }
  .work-card__ph-mark {
    font-family: var(--font-sans);
    font-size: 0.68rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--text-dim);
    padding: 0.4rem 0.8rem;
    border: 1px solid var(--border);
    border-radius: 999px;
  }
  .work-card__year {
    position: absolute;
    left: 0.7rem;
    bottom: 0.7rem;
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    color: var(--text);
    background: color-mix(in srgb, var(--bg) 65%, transparent);
    backdrop-filter: blur(6px);
    padding: 0.25rem 0.6rem;
    border-radius: 999px;
    border: 1px solid var(--border);
  }
  .work-card__info {
    padding-top: 0.9rem;
  }
  .work-card__title {
    font-size: clamp(1.05rem, 2.2vw, 1.35rem);
    letter-spacing: -0.01em;
  }
  .work-card__meta {
    margin: 0.3rem 0 0;
    color: var(--text-dim);
    font-size: 0.82rem;
    letter-spacing: 0.02em;
  }
  @media (min-width: 640px) {
    .work-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 960px) {
    .work-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* ---------------------------- COMPANIES ----------------------------- */
  .companies {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: 1fr;
  }
  .company {
    display: block;
    padding: clamp(1.5rem, 3.5vw, 2.25rem);
    border: 1px solid var(--border);
    border-radius: 14px;
    background: var(--bg-soft);
    transition: border-color 0.3s ease, transform 0.3s ease, background 0.3s ease;
  }
  .company:hover {
    border-color: var(--border-strong);
    transform: translateY(-3px);
    background: var(--surface);
  }
  .company__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .company__name {
    font-size: 1.4rem;
  }
  .company__arrow {
    color: var(--text-dim);
    transition: transform 0.3s ease, color 0.3s ease;
  }
  .company:hover .company__arrow {
    transform: translate(3px, -3px);
    color: var(--text);
  }
  .company__place {
    display: block;
    margin-top: 0.4rem;
    color: var(--text-dim);
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .company__body {
    margin: 1rem 0 0;
    color: var(--text-muted);
    font-size: 0.95rem;
  }
  @media (min-width: 820px) {
    .companies {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* ---------------------------- EDUCATION ----------------------------- */
  .education {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1px;
    background: var(--border);
    border-block: 1px solid var(--border);
    grid-template-columns: 1fr;
  }
  .edu {
    background: var(--bg);
    padding: clamp(1.5rem, 3.5vw, 2.5rem) 0;
  }
  .edu__degree {
    font-size: clamp(1.3rem, 2.6vw, 1.7rem);
    letter-spacing: -0.01em;
  }
  .edu__inst {
    margin: 0.6rem 0 0;
    color: var(--text-muted);
    font-size: 1rem;
  }
  .edu__detail {
    margin: 0.25rem 0 0;
    color: var(--text-dim);
    font-size: 0.85rem;
    letter-spacing: 0.02em;
  }
  @media (min-width: 760px) {
    .education {
      grid-template-columns: 1fr 1fr;
      gap: 1px;
    }
    .edu {
      padding: clamp(1.75rem, 3vw, 2.5rem);
    }
  }

  /* -------------------------- CLIENTS STRIP --------------------------- */
  .clients-strip {
    margin-top: clamp(2.5rem, 5vw, 4rem);
    padding-top: 2rem;
    border-top: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .clients-strip__label {
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-dim);
  }
  .clients-strip__list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem 1.9rem;
    align-items: center;
  }
  .client {
    font-family: var(--font-display);
    font-size: clamp(1.05rem, 2vw, 1.4rem);
    color: var(--text-dim);
    transition: color 0.3s ease;
  }
  .client:hover {
    color: var(--text);
  }

  /* ----------------------------- CONTACT ------------------------------ */
  .contact__headline {
    font-size: clamp(2rem, 6vw, 4rem);
    max-width: 16ch;
    margin-bottom: 1.5rem;
  }
  .contact__intro {
    max-width: 46ch;
    margin: 0 0 2.5rem;
    color: var(--text-muted);
    font-size: clamp(1rem, 1.6vw, 1.15rem);
    line-height: 1.6;
  }
  .contact__email {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 3vw, 2rem);
    color: var(--text);
    border-bottom: 1px solid var(--border-strong);
    padding-bottom: 0.2rem;
    transition: color 0.25s ease, border-color 0.25s ease;
  }
  .contact__email:hover {
    color: var(--accent);
    border-color: var(--text);
  }
  .contact__social {
    display: flex;
    flex-wrap: wrap;
    gap: 1.75rem;
    margin-top: 2.75rem;
  }
  .contact__social a {
    color: var(--text-muted);
    font-size: 0.9rem;
    letter-spacing: 0.02em;
    transition: color 0.25s ease;
  }
  .contact__social a:hover {
    color: var(--text);
  }
</style>
