---
import '../styles/global.css';
import { site, companies } from '../data/content';

const { title = `${site.name} — ${site.role}`, description = site.seoDescription } = Astro.props;

const siteUrl = Astro.site?.href ?? 'https://sebastiancepeda.com/';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
const ogImage = new URL('/portrait.jpg', siteUrl).href;

// schema.org Person — helps SEO and how AI / search engines understand who you are.
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: site.name,
  jobTitle: site.role,
  description: site.seoDescription,
  url: siteUrl,
  image: ogImage,
  email: `mailto:${site.email}`,
  worksFor: companies.map((c) => ({ '@type': 'Organization', name: c.name, url: c.href })),
  address: site.locations.map((l) => ({ '@type': 'PostalAddress', addressLocality: l })),
  sameAs: site.social.map((s) => s.href),
  knowsLanguage: ['Spanish', 'English', 'German', 'French', 'Italian'],
};

const nav = [
  { label: 'About', href: '#about' },
  { label: 'Work', href: '#work' },
  { label: 'Companies', href: '#companies' },
  { label: 'Contact', href: '#contact' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={site.name} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={site.name} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500&family=Inter:wght@400;500;600&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500&family=Inter:wght@400;500;600&display=swap"
      />
    </noscript>
  </head>

  <body>
    <header class="nav">
      <div class="wrap nav__inner">
        <a class="nav__brand" href="#top">{site.name}</a>
        <nav class="nav__links">
          {nav.map((n) => <a href={n.href}>{n.label}</a>)}
        </nav>
        <a class="nav__cta" href="#contact">Get in touch</a>
      </div>
    </header>

    <main id="top">
      <slot />
    </main>

    <footer class="footer">
      <div class="wrap footer__inner">
        <span>© {new Date().getFullYear()} {site.name}</span>
        <span class="footer__meta">{site.locations.join(' · ')}</span>
        <a href={`mailto:${site.email}`}>{site.email}</a>
      </div>
    </footer>

    <style>
      .nav {
        position: sticky;
        top: 0;
        z-index: 50;
        backdrop-filter: saturate(160%) blur(12px);
        background: color-mix(in srgb, var(--bg) 72%, transparent);
        border-bottom: 1px solid var(--border);
      }
      .nav__inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 64px;
        gap: 1rem;
      }
      .nav__brand {
        font-family: var(--font-display);
        font-size: 1.05rem;
        letter-spacing: -0.01em;
      }
      .nav__links {
        display: none;
        gap: 2rem;
      }
      .nav__links a {
        font-size: 0.9rem;
        color: var(--text-muted);
        transition: color 0.25s ease;
      }
      .nav__links a:hover {
        color: var(--text);
      }
      .nav__cta {
        font-size: 0.82rem;
        letter-spacing: 0.02em;
        padding: 0.5rem 1rem;
        border: 1px solid var(--border-strong);
        border-radius: 999px;
        color: var(--text);
        transition: background 0.25s ease, color 0.25s ease;
      }
      .nav__cta:hover {
        background: var(--text);
        color: var(--bg);
      }
      @media (min-width: 760px) {
        .nav__links {
          display: flex;
        }
      }

      .footer {
        border-top: 1px solid var(--border);
      }
      .footer__inner {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem 2rem;
        align-items: center;
        justify-content: space-between;
        padding-block: 2.5rem;
        color: var(--text-dim);
        font-size: 0.85rem;
      }
      .footer__inner a:hover {
        color: var(--text);
      }
      .footer__meta {
        letter-spacing: 0.14em;
        text-transform: uppercase;
        font-size: 0.72rem;
      }
    </style>

    <script>
      // Reveal-on-scroll — purely progressive; content is visible without JS.
      const els = document.querySelectorAll('.reveal');
      if ('IntersectionObserver' in window) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('is-in');
                io.unobserve(e.target);
              }
            }
          },
          { rootMargin: '0px 0px -10% 0px', threshold: 0.1 }
        );
        els.forEach((el) => io.observe(el));
      } else {
        els.forEach((el) => el.classList.add('is-in'));
      }
    </script>
  </body>
</html>
